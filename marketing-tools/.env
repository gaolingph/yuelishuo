# ─── 乐说邦客户服务系统 · 环境配置 ───
# 复制此文件为 .env 并修改配置

# JWT 密钥（生产环境请更换为随机字符串）
JWT_SECRET=marketing-tools-jwt-secret-key-2025

# 数据库连接
# SQLite（开发环境）
DATABASE_URL=sqlite:///./marketing_tools.db
# PostgreSQL（生产环境 - 取消注释）
# DATABASE_URL=postgresql://user:password@localhost:5432/marketing_tools

# 高德地图 API Key（学校采集功能）
AMAP_API_KEY=YOUR_AMAP_KEY_HERE

# 短信网关（阿里云 / 腾讯云）
SMS_PROVIDER=mock          # mock | aliyun | tencent
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=乐说邦        # 短信签名
SMS_TEMPLATE_CODE=          # 验证码短信模板ID

# 邮件服务（SendGrid）
MAIL_PROVIDER=mock          # mock | sendgrid
SENDGRID_API_KEY=
MAIL_FROM=noreply@leshuobang.com

# 服务器配置
HOST=0.0.0.0
PORT=8080
DEBUG=true

# Redis（生产环境建议使用）
REDIS_URL=redis://localhost:6379/0

# 社交媒体平台密钥（自媒体拓客用）
DOUYIN_APP_ID=
DOUYIN_APP_SECRET=
XHS_COOKIE=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
